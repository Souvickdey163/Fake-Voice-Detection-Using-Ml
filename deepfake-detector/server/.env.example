# Deployment Environment Variables
# Create a .env file locally, or configure these in your Railway Dashboard

# Allowed Production Frontend Origin for CORS (Vercel URL)
FRONTEND_URL=https://your-frontend-deployment-url.vercel.app

# MongoDB Connection String (Atlas or Database URI)
MONGO_URI=mongodb+srv://deepfake_user:Souvickdey2005@voice-detection-db.kucgewe.mongodb.net/?retryWrites=true&w=majority

# JWT Auth
JWT_SECRET=your_secure_random_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth Client ID
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Email / SMTP Credentials (for OTP)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Hugging Face Space for ML inference.
# Use either the full Space URL or owner/space-name.
# If this is not set, the backend falls back to the local PyTorch model.
HF_SPACE_URL=https://your-username-your-space-name.hf.space
HF_API_NAME=/predict
HF_MAX_RETRIES=3
HF_RETRY_DELAY_SECONDS=2
